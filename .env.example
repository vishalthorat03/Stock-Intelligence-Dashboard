# Environment configuration
DEBUG=True
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_PATH=backend/data/stocks.db

# Scraper
NSE_URL=https://www.nseindia.com/api/equity-stockIndices
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_COUNT=3
USE_YFINANCE_FALLBACK=True

# ML Configuration
MOMENTUM_WINDOW=20
SENTIMENT_WEIGHT=0.3
MOMENTUM_WEIGHT=0.4
VOLUME_WEIGHT=0.3

# API
API_PORT=5000
API_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs

# Optional OpenAI reasoning
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
OPENAI_ENHANCE_REASONING=False
